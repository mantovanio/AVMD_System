diff --git a/scripts/check-renovacao.cjs b/scripts/check-renovacao.cjs
new file mode 100644
index 0000000..2aca921
--- /dev/null
+++ b/scripts/check-renovacao.cjs
@@ -0,0 +1,15 @@
+const pg = require('pg');
+const fs = require('fs');
+const env = fs.readFileSync('/opt/avmd/AVMD_System/backend/.env.local', 'utf8');
+const url = env.match(/DATABASE_URL=(.+)/)[1].trim();
+const c = new pg.Pool({ connectionString: url, ssl: { rejectUnauthorized: false } });
+Promise.all([
+  c.query("SELECT id, body, status, error, created_at FROM communication_outbox WHERE to_address LIKE '%992443779%' ORDER BY created_at DESC LIMIT 5"),
+  c.query("SELECT id, mensagem, direction, sender_name, created_at FROM crm_chat_messages WHERE document_key LIKE '%992443779%' ORDER BY created_at DESC LIMIT 5"),
+]).then(([outbox, msgs]) => {
+  console.log('=== OUTBOX ===');
+  console.log(JSON.stringify(outbox.rows, null, 2));
+  console.log('=== MESSAGES ===');
+  console.log(JSON.stringify(msgs.rows, null, 2));
+  c.end();
+}).catch(e => { console.error(e.message); c.end(); });
