+-- 057_backfill_media_persist.sql
+-- Identifica mensagens com media_url como data: URI que podem ser persistidas
+
+-- Verificar quantas mensagens têm data: URI
+SELECT COUNT(*) as total_data_uri
+FROM crm_chat_messages
+WHERE media_url LIKE 'data:%';
+
+-- Verificar quantas mensagens têm URL do CDN do WhatsApp (precisam de proxy)
+SELECT COUNT(*) as total_whatsapp_cdn
+FROM crm_chat_messages
+WHERE media_url LIKE '%mmg.whatsapp.net%';
+
+-- Verificar quantas mensagens já têm path permanente (/api/chat/files/)
+SELECT COUNT(*) as total_permanent
+FROM crm_chat_messages
+WHERE media_url LIKE '/api/chat/files/%';
diff --git a/backend/sql/057_backfill_media_persist.ts b/backend/sql/057_backfill_media_persist.ts
