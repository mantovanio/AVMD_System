              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"number\": \"{{ $json.numero_empresa }}\",\n  \"text\": \"{{ $json.alerta1 }}\"\n}",
        "options": {}
