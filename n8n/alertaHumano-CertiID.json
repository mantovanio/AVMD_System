    {
      "parameters": {
        "jsCode": "const nome     = $input.first().json.NomeLead    || 'Não identificado';\nconst numero   = $input.first().json.whatsapp_lead || 'Não informado';\nconst assunto  = $input.first().json.assunto       || 'Não especificado';\nconst canal    = $input.first().json.canal         || 'WhatsApp CertiID';\nconst urgRaw   = ($input.first().json.urgencia || '').toLowerCase();\n\nconst urgente  = urgRaw.includes('alta') || urgRaw.includes('urgent');\nconst icone    = urgente ? '🚨' : '⚠️';\nconst tag      = urgente ? 'ALTA' : 'NORMAL';\n\nconst formatNum = (n) => {\n  const d = String(n).replace(/\\D/g, '');\n  return d.startsWith('55') ? d : '55' + d;\n};\n\nconst alerta1 = `${icone} TRANSFERÊNCIA PARA SUPORTE\\n\\n` +\n  `👤 Cliente: ${nome}\\n` +\n  `📱 Número: +${formatNum(numero)}\\n` +\n  `📲 Canal: ${canal}\\n` +\n  `📋 Assunto: ${assunto}\\n` +\n  `⚡ Urgência: ${tag}\\n\\n` +\n  `Retorne o contato o quanto antes.\\n` +\n  `⏰ Sem resposta? Reforço em 10 minutos.`;\n\nconst alerta2 = `⚠️ 1º REFORÇO — SEM RETORNO\\n\\n` +\n  `👤 ${nome}\\n` +\n  `📱 +${formatNum(numero)}\\n` +\n  `📋 ${assunto}\\n\\n` +\n  `O cliente ainda aguarda atendimento!\\n` +\n  `⏰ Novo reforço em 10 minutos se não houver retorno.`;\n\nconst alerta3 = `🚨 2º REFORÇO — URGENTE\\n\\n` +\n  `👤 ${nome}\\n` +\n  `📱 +${formatNum(numero)}\\n` +\n  `📋 ${assunto}\\n\\n` +\n  `Cliente há 20 minutos aguardando atendimento.\\n` +\n  `Por favor, entre em contato imediatamente!`;\n\nreturn [{ json: {\n  numero_empresa: '551132800484',\n  alerta1, alerta2, alerta3\n}}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        368,
        240
      ],
      "id": "9d0d6a85-2aef-4af1-b873-92d878be730b",
      "name": "montarMensagens"
    },
    {
