{
  "name": "AVMD - Event Receiver",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "avmd-events",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-node",
      "name": "AVMD Events Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [420, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ ({ ok: true, received: true, event_type: $json.event_type, entity_type: $json.entity_type, entity_id: $json.entity_id }) }}",
        "options": {
          "responseCode": 200
        }
      },
      "id": "respond-node",
      "name": "Ack AVMD Event",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [700, 300]
    }
  ],
  "connections": {
    "AVMD Events Webhook": {
      "main": [[{ "node": "Ack AVMD Event", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "active": false,
  "versionId": "1"
}
