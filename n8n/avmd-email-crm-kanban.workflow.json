      "id": "switch-node",
      "name": "Switch (Agendado / Cancelado)",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [-1024, -480]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nif (items.length === 0) return [];\nconst item = items[0].json;\n\nconst stripHtml = (html) =>\n  String(html || '')\n    .replace(/<[^>]*>/g, ' ')\n    .replace(/&nbsp;/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n\nconst emailBody = stripHtml(item.textHtml || item.textPlain || '');\nconst extract = (regex) => {\n  const match = emailBody.match(regex);\n  return match ? match[1].trim() : '';\n};\n\nconst cliente = extract(/Cliente:\\s*([\\s\\S]*?)(?=CPF\\/CNPJ:|$)/i);\nconst cpfCnpj = extract(/CPF\\/CNPJ:\\s*([\\d.-]+)/i);\nconst pedido = extract(/Pedido:\\s*(\\d+)/i);\nconst produto = extract(/Produto:\\s*([\\s\\S]*?)(?=Posto:|$)/i);\nconst posto = extract(/Posto:\\s*([\\s\\S]*?)(?=Data:|$)/i);\nconst data = extract(/Data:\\s*(\\d{2}\\/\\d{2}\\/\\d{4})/i);\nconst hora = extract(/Hora:\\s*(\\d{2}:\\d{2})/i);\nconst emailCli = extract(/Email:\\s*([^\\s]+@[^\\s]+\\.[^\\s]+)/i);\n\nlet telRaw = extract(/Telefone:\\s*([\\d()\\-\\s]+)/i);\nlet telefone = telRaw.replace(/\\D/g, '');\nif (telefone.length >= 10 && telefone.length <= 11) {\n  telefone = '55' + telefone;\n}\n\nreturn [{\n  json: {\n    nomeCliente: cliente,\n    primeiroNome: cliente ? cliente.split(' ')[0] : 'Cliente',\n    cpfCnpj,\n    telefone: String(telefone),\n    email: emailCli,\n    pedido,\n    produto,\n    posto,\n    data,\n    hora,\n    corpoEmail: emailBody\n  }\n}];\n"
      },
      "id": "code-extract",
      "name": "Extrair dados do email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-720, -656]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst corpoBruto = item.textHtml || item.textPlain || '';\nconst assunto = item.subject || '';\n\nconst htmlToText = (input) =>\n  String(input || '')\n    .replace(/<[^>]+>/g, ' ')\n    .replace(/&nbsp;/gi, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n\nconst textoCorpo = htmlToText(corpoBruto);\nconst extract = (regex) => {\n  const match = textoCorpo.match(regex);\n  return match ? match[1].trim() : null;\n};\n\nconst pedido = (assunto.match(/pedido\\s*(\\d{5,})/i) || [])[1] || extract(/Pedido:\\s*(\\d{5,})/i);\nconst cliente = extract(/Cliente:\\s*([\\s\\S]*?)(?=\\s*(CPF\\/CNPJ:|Telefone:|Email:|Pedido:|Produto:|Data:|Hora:|$))/i);\nconst telefoneBruto = extract(/Telefone:\\s*([\\d()\\-\\s]+)/i);\nconst emailCliente = extract(/Email:\\s*([^\\s]+@[^\\s]+\\.[^\\s]+)/i);\nconst produto = extract(/Produto:\\s*([\\s\\S]*?)(?=\\s*(Telefone:|Email:|Data:|Hora:|$))/i);\nconst data = extract(/Data:\\s*(\\d{2}\\/\\d{2}\\/\\d{4})/i);\nconst hora = extract(/Hora:\\s*(\\d{2}:\\d{2})/i);\n\nconst telefoneNumeros = (telefoneBruto || '').replace(/\\D/g, '');\nconst telefone = telefoneNumeros ? (telefoneNumeros.startsWith('55') ? telefoneNumeros : '55' + telefoneNumeros) : null;\n\nif (!pedido) {\n  throw new Error('Nao foi possivel identificar o numero do pedido no e-mail.');\n}\n\nreturn {\n  cliente: cliente || 'Cliente',\n  primeiroNome: (cliente || 'Cliente').split(' ')[0],\n  telefone,\n  pedido,\n  email: emailCliente,\n  produto: produto || 'Certificado Digital',\n  data,\n  hora,\n  corpoEmail: textoCorpo\n};\n"
      },
      "id": "code-extract-cancel",
      "name": "Extrair dados do cancelamento",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-720, -80]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.certiid.mantovan.com.br/api/chat/crm/events",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
